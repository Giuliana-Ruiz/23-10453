::zilly+
sys.reset();

Z => Z => Z multPos := fn(Z y) -> fn(Z x) -> if(x = 0, 0, multPos(y)(x - 1) + y);

Z => Z chs := fn(Z n) -> sub(n)(0);

Z => Z => Z mult := fn(Z y) -> fn(Z x) -> if(x < 0, if(y < 0, multPos(chs(y))(chs(x)), chs(multPos(y)(chs(x)))), if(y < 0, chs(multPos(chs(y))(x)), if(x < y, multPos(y)(x), multPos(x)(y))));

mult(3)(4)
mult(4)(3)
mult(0)(5)
mult(5)(0)
mult(-3)(4)
mult(3)(-4)
mult(-3)(-4)
mult(7)(8)
mult(8)(7)
mult(0)(0)
mult(-5)(-6)
mult(1)(99)
mult(99)(1)
